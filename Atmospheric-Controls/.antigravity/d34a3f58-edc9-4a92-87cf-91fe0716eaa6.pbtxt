A2A2A;}.sidebar-label{position:absolute;left:30px;top:50%;transform:translateY(-50%) rotate(-180deg);writing-mode:vertical-rl;font-family:\'Courier New\',monospace;font-size:10px;text-transform:uppercase;letter-spacing:4px;opacity:0.4;}header{height:120px;padding:0 40px 0 120px;display:flex;justify-content:space-between;align-items:center;z-index:10;}header h2{font-family:\'Georgia\',serif;font-weight:400;font-style:italic;font-size:20px;letter-spacing:1px;}header .status{font-family:\'Courier New\',monospace;font-size:9px;text-transform:uppercase;letter-spacing:2px;opacity:0.6;}main{flex:1;display:flex;flex-direction:column;justify-content:center;padding-left:160px;position:relative;z-index:10;}main h1{font-family:\'Georgia\',serif;font-weight:400;font-size:72px;line-height:0.95;margin-bottom:60px;max-width:600px;}main h1 span{display:block;opacity:0.5;font-size:32px;margin-bottom:10px;}.controls{display:flex;gap:40px;}.formal-btn{background:transparent;color:#E8E4DF;border:1px solid #4A4A4A;padding:20px 48px;font-family:\'Courier New\',monospace;text-transform:uppercase;letter-spacing:4px;font-size:11px;cursor:pointer;transition:all 0.4s cubic-bezier(0.16,1,0.3,1);position:relative;}.formal-btn:hover{background:#E8E4DF;color:#0A0A0A;border-color:#E8E4DF;transform:translateY(-2px);}.formal-btn:active{transform:translateY(0);}footer{height:80px;padding:0 40px 0 120px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid #2A2A2A;font-family:\'Courier New\',monospace;font-size:9px;opacity:0.3;text-transform:uppercase;letter-spacing:2px;}.snowflake{position:fixed;top:-40px;color:#FFF;font-size:24px;pointer-events:none;z-index:1000;animation:fall 5s linear forwards;}.balloon{position:fixed;bottom:-60px;font-size:40px;pointer-events:none;z-index:1000;animation:rise 5s ease-in forwards;}@keyframes fall{0%{transform:translateY(0) rotate(0deg);opacity:0;}10%{opacity:1;}100%{transform:translateY(800px) rotate(360deg);opacity:0.3;}}@keyframes rise